{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreBinaries": ["ssh-keygen"],
  "ignoreDependencies": ["ovsx"],
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true,
    "function": true
  },
  "entry": [
    "src/extension.ts",
    "src/host/index.ts",
    "src/host/treeView.ts",
    "src/builtin-disable/index.ts",
    "src/webview/configPanel.ts",
    "scripts/askpass/askpass-main.js",
    "scripts/download-busybox.mjs",
    "scripts/download-vscodium-versions.mjs"
  ],
  "project": ["src/**", "test/unit/**", "test/property/**", "scripts/**"]
}
