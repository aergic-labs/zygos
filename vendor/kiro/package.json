{
  "name": "zygos-kiro",
  "displayName": "Zygos Remote SSH for Kiro",
  "description": "Connect to any remote machine via SSH from Kiro. Open folders on remote hosts, run a full IDE-backed server, and chain into devcontainers - all over a stock ssh binary.",
  "keywords": [
    "kiro",
    "remote ssh",
    "remote-ssh",
    "ssh",
    "remote",
    "remote development",
    "devcontainer"
  ],
  "platform": {
    "name": "Kiro",
    "applicationName": "kiro",
    "dataFolderName": ".kiro",
    "serverApplicationName": "kiro-server",
    "serverDataFolderName": ".kiro-server",
    "needsArgvPatch": true
  },
  "__strip": {
    "activationEvents": [
      "onCommand:zygos.testDownloadUrl"
    ],
    "commands": [
      "zygos.testDownloadUrl",
      "zygos.showConflictInfo"
    ],
    "configuration": []
  }
}
